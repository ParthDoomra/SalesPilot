# SalesPilot AI Backend Configuration

PORT=8000
DEMO_MODE=true

# Claude API
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Firebase Admin configuration (Optional if DEMO_MODE=true)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Redis / Upstash Redis cache (Optional, fell back to in-memory cache if DEMO_MODE=true)
# REDIS_URL=rediss://default:your_password@your_endpoint.upstash.io:6379

# Azure Retail Pricing API (Optional fallback)
AZURE_PRICING_API_URL=https://prices.azure.com/api/retail/prices
